# Brain Gateway Environment Configuration
# =========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Or run the interactive setup:
#   ./setup.sh

# =============================================================================
# NETWORK NODES - IP addresses of cluster machines
# =============================================================================

# Jupiter - Main gateway host (orchestrator, Open WebUI)
NODE_JUPITER_IP=10.0.0.248

# Saturn - Reserve GPU capacity (RTX 3080 + RTX 3090)
NODE_SATURN_IP=10.0.0.58

# Uranus - TTS/STT server (2x RTX 5080)
NODE_URANUS_IP=10.0.0.173

# Helios - Primary model server (RTX 5090) - always-on
NODE_HELIOS_IP=10.0.0.195

# Home Assistant server
NODE_HA_IP=10.0.0.106

# =============================================================================
# PATHS - File system locations
# =============================================================================

# Root path of the gateway installation
GATEWAY_ROOT_PATH=/opt/jupiter/gateway_mvp

# User home directory (for volume mounts)
USER_HOME=/home/labadmin

# RAG data directory
RAG_BASE=/home/labadmin/rag/nadim_rag

# ChromaDB persistence path
CHROMA_PERSIST=/home/labadmin/.local/share/chroma/personal_rag

# =============================================================================
# SECRETS - MUST BE SET (no defaults)
# =============================================================================

# API authentication token (required — protects all orchestrator endpoints)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=your-api-token-here

# Home Assistant long-lived access token
# Get from: HA > Profile > Long-Lived Access Tokens > Create Token
HA_TOKEN=your-ha-token-here

# LiteLLM master key for API authentication
LITELLM_MASTER_KEY=your-litellm-key-here

# Grafana admin password
GF_SECURITY_ADMIN_PASSWORD=your-grafana-password-here

# =============================================================================
# SERVICE PORTS - Change only if ports conflict
# =============================================================================

# Orchestrator API port
SERVICE_ORCHESTRATOR_PORT=8888

# LiteLLM proxy port
SERVICE_LITELLM_PORT=4000

# Open WebUI port
SERVICE_WEBUI_PORT=80

# TTS service port (Qwen3-TTS)
SERVICE_TTS_PORT=8002

# STT service port (Whisper)
SERVICE_STT_PORT=8003

# Primary model server port (llama.cpp on Helios)
SERVICE_MODEL_PORT=8080

# Wyoming Whisper STT (for voice assistant pipeline)
WYOMING_WHISPER_PORT=10300

# Wyoming Jessica TTS bridge (for voice assistant pipeline)
WYOMING_JESSICA_PORT=10301

# =============================================================================
# MONITORING PORTS
# =============================================================================

# Grafana dashboard
MONITORING_GRAFANA_PORT=3000

# Prometheus
MONITORING_PROMETHEUS_PORT=9090

# Loki log aggregation
MONITORING_LOKI_PORT=3100

# Node exporter (system metrics)
MONITORING_NODE_EXPORTER_PORT=9100

# GPU exporter
MONITORING_GPU_EXPORTER_PORT=9400

# Blackbox exporter (HTTP probes)
MONITORING_BLACKBOX_PORT=9115

# =============================================================================
# SERVICE URLS - Derived from above (override if needed)
# =============================================================================

# Primary model (conversation + tools)
MODEL_URL=http://${NODE_HELIOS_IP:-10.0.0.195}:${SERVICE_MODEL_PORT:-8080}/v1

# Fallback model (used when primary is unavailable)
FALLBACK_MODEL_URL=http://${NODE_SATURN_IP:-10.0.0.58}:8001/v1

# Home Assistant API
HA_URL=http://${NODE_HA_IP:-10.0.0.106}:8123

# TTS service
TTS_URL=http://${NODE_URANUS_IP:-10.0.0.173}:${SERVICE_TTS_PORT:-8002}

# STT service
STT_URL=http://${NODE_URANUS_IP:-10.0.0.173}:${SERVICE_STT_PORT:-8003}

# Orchestrator callback URL (for HA to reach orchestrator)
ORCHESTRATOR_URL=http://${NODE_JUPITER_IP:-10.0.0.248}:${SERVICE_ORCHESTRATOR_PORT:-8888}

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================

# Primary model name
MODEL_NAME=Qwen3.5-27B

# Fallback model name
FALLBACK_MODEL_NAME=Qwen3.5-9B

# Embedding model (for RAG and auto-learn)
# After changing, run: python scripts/reindex_rag.py --persist $CHROMA_PERSIST --collection $CHROMA_COLLECTION
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v2-moe

# TTS voice name
TTS_VOICE=jessica

# =============================================================================
# RAG CONFIGURATION
# =============================================================================

# ChromaDB collection name
CHROMA_COLLECTION=nadim_rag

# Minimum cosine similarity for RAG results
MIN_COS=0.20

# Maximum number of RAG results to return
TOP_K=25

# =============================================================================
# SSH CONFIGURATION - For remote model server management
# =============================================================================

# Model server IP (defaults to NODE_HELIOS_IP if not set)
# MODEL_SERVER_IP=10.0.0.195

# Model server SSH user
MODEL_SSH_USER=labadmin

# SSH key path (inside container, mounted from host)
MODEL_SSH_KEY=/root/.ssh/id_ed25519

# Commands to start/stop the model server via SSH (optional)
# MODEL_START_CMD=sudo systemctl start llama-server
# MODEL_STOP_CMD=sudo systemctl stop llama-server

# =============================================================================
# REMINDER CONFIGURATION
# =============================================================================

# Default speaker for voice reminders
REMINDER_SPEAKER=media_player.whole_home

# Fallback speaker if primary speaker fails (TTS announcements + reminders)
FALLBACK_SPEAKER=media_player.dining_room_pair

# Default speaker for focus timer audio (Endel)
FOCUS_AUDIO_PLAYER=media_player.whole_home

# Mobile notification target
MOBILE_NOTIFY=notify.mobile_app_nadims_iphone

# Timezone
TZ=America/Chicago

# =============================================================================
# GRAFANA CONFIGURATION
# =============================================================================

# Grafana admin username
GF_SECURITY_ADMIN_USER=admin

# Disable user signup
GF_USERS_ALLOW_SIGN_UP=false

# =============================================================================
# AGENTIC SETTINGS
# =============================================================================

# Maximum tool call rounds to prevent infinite loops
MAX_TOOL_ROUNDS=5

# =============================================================================
# PI-HOLE CONFIGURATION - Focus mode distraction blocking
# =============================================================================

# Pi-hole web interface port (default 8053 to avoid conflicts with Open WebUI)
PIHOLE_WEB_PORT=8053

# Pi-hole admin password (required for API access)
PIHOLE_PASSWORD=your-pihole-password-here

# Pi-hole API URLs (comma-separated for multi-instance: Jupiter + Saturn)
PIHOLE_URLS=http://10.0.0.248:8053,http://10.0.0.58:8053

# Focus blocking group name in Pi-hole (create this group in Pi-hole admin)
PIHOLE_FOCUS_GROUP=focus_blocklist

# Enable/disable focus blocking feature (default: true)
FOCUS_BLOCKING_ENABLED=true

# =============================================================================
# SEARXNG CONFIGURATION - Web search via self-hosted meta search engine
# =============================================================================

# SearXNG web interface port
SEARXNG_PORT=8090

# SearXNG API URL (internal Docker network)
SEARXNG_URL=http://searxng:8080

# Maximum number of search results to return per query
SEARXNG_MAX_RESULTS=5

# =============================================================================
# GOOGLE CALENDAR CONFIGURATION
# =============================================================================

# Path to OAuth2 credentials JSON (from Google Cloud Console)
GOOGLE_CREDENTIALS_PATH=/app/credentials/google_credentials.json

# Path to saved OAuth2 token (generated by google_setup.py)
GOOGLE_TOKEN_PATH=/app/credentials/google_token.json

# Calendar polling interval in minutes (for proactive reminders)
CALENDAR_POLL_INTERVAL=5

# Enable tiered countdown alerts (60/30/15/5 min before events)
CALENDAR_TIERED_ALERTS=true

# Tier thresholds in minutes (comma-separated, descending)
CALENDAR_ALERT_TIERS=60,30,15,5

# Morning briefing time (HH:MM, 24-hour format)
MORNING_BRIEFING_TIME=07:30

# Enable/disable morning briefing (default: true)
MORNING_BRIEFING_ENABLED=true

# =============================================================================
# GMAIL CONFIGURATION
# =============================================================================

# Email polling interval in minutes (for proactive new email announcements)
EMAIL_POLL_INTERVAL=30

# Enable/disable email polling (default: true)
EMAIL_POLL_ENABLED=true

# Enable/disable auto-extracting events from emails and adding to calendar
EMAIL_TO_CALENDAR_ENABLED=true

# How often to scan emails for events (minutes, default: 60)
EMAIL_TO_CALENDAR_INTERVAL=60

# =============================================================================
# PHONE CALENDAR SYNC - iPhone Shortcut pushes consolidated calendar
# =============================================================================

# Enable/disable phone calendar sync (default: true)
PHONE_CALENDAR_SYNC_ENABLED=true

# =============================================================================
# UI CUSTOMIZATION
# =============================================================================

# Open WebUI display name
WEBUI_NAME=Brain Gateway
