# Brain Gateway Environment Configuration
# =========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Or run the interactive setup:
#   ./setup.sh

# =============================================================================
# NETWORK NODES - IP addresses of cluster machines
# =============================================================================

# Replace these with your own LAN/Tailscale addresses. Single-box installs
# can leave the non-Helios nodes empty and disable the corresponding optional
# integrations; the orchestrator already falls back gracefully via service_registry.
#
# Helios - Gateway + Primary LLM + TTS/STT (always-on box)
NODE_HELIOS_IP=10.0.0.10

# Jupiter - optional: monitoring stack (Prometheus, Grafana, Loki, Promtail)
NODE_JUPITER_IP=

# Saturn - optional: reserve GPU capacity (vision, expert reasoning)
NODE_SATURN_IP=

# Home Assistant server (leave empty if no HA)
NODE_HA_IP=

# =============================================================================
# PATHS - File system locations
# =============================================================================

# Root path of the gateway installation — the directory containing this
# .env file. install.sh writes this to your actual clone path automatically.
# Manual installs: set to the absolute path of `pwd` after `git clone`.
# Leave at the default (empty) and Docker bind-mounts will resolve relative
# to wherever `docker compose` is invoked from.
GATEWAY_ROOT_PATH=

# User home directory (for volume mounts)
USER_HOME=${HOME}

# RAG data directory (your personal documents corpus)
RAG_BASE=${HOME}/rag/personal

# ChromaDB persistence path
CHROMA_PERSIST=${HOME}/.local/share/chroma/personal_rag

# =============================================================================
# SECRETS - MUST BE SET (no defaults)
# =============================================================================

# API authentication token (required — protects all orchestrator endpoints)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=your-api-token-here

# Dashboard login password (asked for by the web /login form at port 3001).
# install.sh generates a random value; setup.sh prints it at end-of-install.
# The literal string 'changeme' is the insecure default — if you see that
# at the /login prompt, set this to something random and rebuild the frontend.
DASHBOARD_TOKEN=

# Home Assistant long-lived access token
# Get from: HA > Profile > Long-Lived Access Tokens > Create Token
HA_TOKEN=your-ha-token-here

# Grafana admin password
GF_SECURITY_ADMIN_PASSWORD=your-grafana-password-here

# =============================================================================
# SERVICE PORTS - Change only if ports conflict
# =============================================================================

# Orchestrator API port
SERVICE_ORCHESTRATOR_PORT=8888

# Open WebUI port
SERVICE_WEBUI_PORT=80

# TTS service port (Qwen3-TTS)
SERVICE_TTS_PORT=8002

# STT service port (Whisper)
SERVICE_STT_PORT=8003

# Primary model server port (llama.cpp on Helios)
SERVICE_MODEL_PORT=8080

# Wyoming Whisper STT (for voice assistant pipeline)
WYOMING_WHISPER_PORT=10300

# Wyoming Jessica TTS bridge (for voice assistant pipeline)
WYOMING_JESSICA_PORT=10301

# =============================================================================
# MONITORING PORTS
# =============================================================================

# Grafana dashboard
MONITORING_GRAFANA_PORT=3000

# Prometheus
MONITORING_PROMETHEUS_PORT=9090

# Loki log aggregation
MONITORING_LOKI_PORT=3100

# Loki push URL for the Helios-side promtail sidecar. Required if you turn on
# the `advanced` compose profile (which brings up promtail). Set to your Loki
# push endpoint, e.g. http://loki.example.tld:3100/loki/api/v1/push.
# Empty here is fine — promtail simply doesn't start under the default profile.
LOKI_PUSH_URL=

# Compose profile selector. Comma-separated for multiple. See docs/ENV_VARS.md.
#   models   — run vLLM + Qwen3-TTS + Parakeet STT as containers. A fresh
#              single-box install wants this. (On Helios the model layer runs
#              as host systemd units, so `models` is intentionally left out
#              there to avoid double-starting them.)
#   advanced — operator services: nebula-sync, promtail, nut-exporter.
# Default empty leaves only the core stack: orchestrator + open-webui + redis
# + searxng + frontend + wyoming bridges.
COMPOSE_PROFILES=

# Node exporter (system metrics)
MONITORING_NODE_EXPORTER_PORT=9100

# GPU exporter
MONITORING_GPU_EXPORTER_PORT=9400

# Blackbox exporter (HTTP probes)
MONITORING_BLACKBOX_PORT=9115

# =============================================================================
# SERVICE URLS - Derived from above (override if needed)
# =============================================================================

# Primary model (conversation + tools).
# When running vllm-primary in the same compose project, use the service
# DNS name so the orchestrator container can reach it on the gateway-net
# network. The container listens on 8000 internally (mapped to 8080 on
# the host).
MODEL_URL=http://vllm-primary:8000/v1

# Fallback model (used when primary is unavailable). Optional: leave empty
# if you don't run a second model. Saturn box example shown.
FALLBACK_MODEL_URL=

# Home Assistant API (leave empty to disable HA integration)
HA_URL=

# TTS service. Inside the compose network, reach qwen-tts by its service
# DNS name. (On the host these are also bound to 127.0.0.1:8002 / :8003,
# but the orchestrator container's `localhost` is the container itself,
# not the host.)
TTS_URL=http://qwen-tts:8002

# STT service.
STT_URL=http://parakeet-stt:8003

# Orchestrator callback URL — used by Home Assistant + external clients
# (NOT inside-compose) to reach the orchestrator. JESS_LAN_IP is written
# by install.sh to the host's real LAN IP.
ORCHESTRATOR_URL=http://${JESS_LAN_IP:-localhost}:${SERVICE_ORCHESTRATOR_PORT:-8888}

# =============================================================================
# MODEL LAYER  (compose profile: models)
# =============================================================================
# These knobs feed the vllm-primary / qwen-tts / parakeet-stt compose services.
# They only start when COMPOSE_PROFILES includes `models` (see above). Run
# `bash scripts/detect_hardware.sh` for a VRAM-tiered VLLM_MODEL suggestion.

# Host interface the model-layer ports bind to. Default 127.0.0.1 (loopback
# only) — the model APIs are unauthenticated, and the orchestrator reaches
# them over the compose network, not the published port. Set to 0.0.0.0 only
# if you need to hit vLLM/TTS/STT from another machine on your LAN.
MODEL_BIND_ADDR=127.0.0.1

# Primary LLM served by vLLM.
#   24GB tier → Qwen/Qwen3-14B-Instruct-AWQ
#   32/48GB tier → Lorbus/Qwen3.6-27B-int4-AutoRound
VLLM_MODEL=Lorbus/Qwen3.6-27B-int4-AutoRound
VLLM_SERVED_NAME=qwen3.6-27b-int4
# vLLM --quantization. `auto_round` suits the default AutoRound model; use
# `awq` for AWQ models, or `auto` to let vLLM detect from the model config.
VLLM_QUANTIZATION=auto_round
VLLM_MAX_MODEL_LEN=153600
VLLM_GPU_MEM_UTIL=0.93

# VRAM tier (24 | 32 | 48) — written by scripts/detect_hardware.sh.
JESS_VRAM_TIER=

# Qwen3-TTS — model downloads from HuggingFace into the model-hf-cache volume.
QWEN_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
# To use a local (non-HuggingFace) TTS model — e.g. a cloning-capable *-Base
# model — set QWEN_TTS_MODEL_DIR to its host directory and QWEN_TTS_MODEL to
# /models/local (its in-container mount point).
# QWEN_TTS_MODEL_DIR=
QWEN_TTS_DTYPE=bfloat16
QWEN_TTS_FLASH_ATTN=false
# Host dir for cloned-voice files (voices.json + reference wavs).
TTS_VOICES_PATH=./data/tts_voices

# Parakeet STT model (downloads from HuggingFace).
PARAKEET_MODEL=nvidia/parakeet-tdt-0.6b-v3

# When the model layer runs in compose, point the orchestrator at the
# compose-internal service names instead of host IPs:
#   MODEL_URL=http://vllm-primary:8000/v1
#   TTS_URL=http://qwen-tts:8002
#   STT_URL=http://parakeet-stt:8003

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================

# Primary model name. MUST match VLLM_SERVED_NAME above — that's the
# name the orchestrator will send to vLLM via the OpenAI-compatible API.
MODEL_NAME=qwen3.6-27b-int4

# Fallback model name
FALLBACK_MODEL_NAME=Qwen3.5-9B

# Embedding model (for RAG and auto-learn)
# After changing, run: python scripts/reindex_rag.py --persist $CHROMA_PERSIST --collection $CHROMA_COLLECTION
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v2-moe

# TTS voice name
TTS_VOICE=jessica

# =============================================================================
# RAG CONFIGURATION
# =============================================================================

# ChromaDB collection name
CHROMA_COLLECTION=personal_rag

# Minimum cosine similarity for RAG results
MIN_COS=0.20

# Maximum number of RAG results to return
TOP_K=25

# =============================================================================
# SSH CONFIGURATION - For remote model server management
# =============================================================================

# Model server IP (defaults to NODE_HELIOS_IP if not set)
# MODEL_SERVER_IP=

# Model server SSH user (matches the account that owns the model service)
MODEL_SSH_USER=

# SSH key path (inside container, mounted from host)
MODEL_SSH_KEY=/root/.ssh/id_ed25519

# Commands to start/stop the model server via SSH (optional)
# MODEL_START_CMD=sudo systemctl start llama-server
# MODEL_STOP_CMD=sudo systemctl stop llama-server

# =============================================================================
# REMINDER CONFIGURATION
# =============================================================================

# Default speaker for voice reminders. May be comma-separated for multi-room
# broadcast (avoids Google Home group issues with soundbars).
REMINDER_SPEAKER=media_player.whole_home

# Default speaker for focus timer audio (Endel)
FOCUS_AUDIO_PLAYER=media_player.whole_home

# Lo-fi stream URL for focus sessions (body doubling audio option)
# FOCUS_AUDIO_LOFI_URL=https://example.com/lofi-stream

# Coffee shop stream URL for focus sessions (body doubling audio option)
# FOCUS_AUDIO_COFFEE_URL=https://example.com/coffee-shop-stream

# Mobile notification target — your HA Companion notify service entity
# (e.g. notify.mobile_app_<your_phone_name>). Leave empty to disable.
MOBILE_NOTIFY=

# Timezone
TZ=America/Chicago

# =============================================================================
# GRAFANA CONFIGURATION
# =============================================================================

# Grafana admin username
GF_SECURITY_ADMIN_USER=admin

# Disable user signup
GF_USERS_ALLOW_SIGN_UP=false

# =============================================================================
# AGENTIC SETTINGS
# =============================================================================

# Maximum tool call rounds to prevent infinite loops
MAX_TOOL_ROUNDS=5

# =============================================================================
# PI-HOLE CONFIGURATION - Focus mode distraction blocking
# =============================================================================

# Pi-hole web interface port (default 8053 to avoid conflicts with Open WebUI)
PIHOLE_WEB_PORT=8053

# Pi-hole admin password (required for API access)
PIHOLE_PASSWORD=your-pihole-password-here

# Pi-hole API URLs (comma-separated for multi-instance). Leave empty to
# disable focus-mode DNS blocking; the orchestrator falls back to a TTS-only
# focus session when this is unset.
PIHOLE_URLS=

# Focus blocking group name in Pi-hole (create this group in Pi-hole admin)
PIHOLE_FOCUS_GROUP=focus_blocklist

# Enable/disable focus blocking feature (default: true)
FOCUS_BLOCKING_ENABLED=true

# =============================================================================
# SEARXNG CONFIGURATION - Web search via self-hosted meta search engine
# =============================================================================

# SearXNG web interface port
SEARXNG_PORT=8090

# SearXNG API URL (internal Docker network)
SEARXNG_URL=http://searxng:8080

# Maximum number of search results to return per query
SEARXNG_MAX_RESULTS=5

# =============================================================================
# GOOGLE CALENDAR CONFIGURATION
# =============================================================================

# Path to OAuth2 credentials JSON (from Google Cloud Console)
GOOGLE_CREDENTIALS_PATH=/app/credentials/google_credentials.json

# Path to saved OAuth2 token (generated by google_setup.py)
GOOGLE_TOKEN_PATH=/app/credentials/google_token.json

# Calendar polling interval in minutes (for proactive reminders)
CALENDAR_POLL_INTERVAL=5

# Enable tiered countdown alerts (60/30/15/5 min before events)
CALENDAR_TIERED_ALERTS=true

# Tier thresholds in minutes (comma-separated, descending)
CALENDAR_ALERT_TIERS=60,30,15,5

# Morning briefing time (HH:MM, 24-hour format)
MORNING_BRIEFING_TIME=07:30

# Enable/disable morning briefing (default: true)
MORNING_BRIEFING_ENABLED=true

# =============================================================================
# GMAIL CONFIGURATION
# =============================================================================

# Email polling interval in minutes (for proactive new email announcements)
EMAIL_POLL_INTERVAL=30

# Enable/disable email polling (default: true)
EMAIL_POLL_ENABLED=true

# Enable/disable auto-extracting events from emails and adding to calendar
EMAIL_TO_CALENDAR_ENABLED=true

# How often to scan emails for events (minutes, default: 60)
EMAIL_TO_CALENDAR_INTERVAL=60

# =============================================================================
# PHONE CALENDAR SYNC - iPhone Shortcut pushes consolidated calendar
# =============================================================================

# Enable/disable phone calendar sync (default: true)
PHONE_CALENDAR_SYNC_ENABLED=true

# =============================================================================
# VISION / IMAGE RECOGNITION - Dedicated vision model on Saturn
# =============================================================================

# Enable/disable vision (image analysis) feature
VISION_ENABLED=true

# Vision model URL — point at your vision-capable model server (e.g.
# http://${NODE_SATURN_IP}:8010/v1 if you run it on a separate GPU box).
# Leave empty to disable vision; the orchestrator will skip image analysis.
VISION_MODEL_URL=

# Vision model name
VISION_MODEL_NAME=Qwen2.5-VL-7B-Instruct-q4_k_m.gguf

# Maximum image upload size in bytes (default: 10MB)
VISION_MAX_IMAGE_SIZE=10485760

# Vision model request timeout in seconds
VISION_TIMEOUT=60

# =============================================================================
# UI CUSTOMIZATION
# =============================================================================

# Open WebUI display name
WEBUI_NAME=Brain Gateway
