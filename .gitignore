# Secrets - NEVER commit these
.env
*.env
*secret*
*token*
# ...but this is source code (reads token files at runtime), not a secret:
!scripts/refresh_google_token.py

# Active user profile (contains personal data)
user_profile.yaml
# Owner's personal profile copy — kept on disk, never shipped
user_profile.nadim.yaml

# Backups
*.backup
*.bak
*.bak.*
.env.bak*
data/app-backup-*/
# scripts/backup_state.py output — state archives contain the OAuth token and
# auto_learn.key; never commit them.
backups/
jess-state-*.tar.gz

# Application runtime state (bind-mounted to /app/data in the container).
# Holds progress.db, brain_state.db, finance.db, auto_learn.key, etc.
# Never commit this — contains personal state that changes every run.
data/app/

# Local ML caches / fine-tune artifacts (can be regenerated; bloats the repo)
data/embedding_finetune/
data/hf_cache/

# Wake-word training data — personal voice recordings (biometric) + trained
# models. Never commit; tens of GB and not portable.
data/wakeword/

# Claude Code local state (worktrees, local settings backups)
.claude/worktrees/
.claude/settings.local.json.bak*

# TypeScript build cache
tsconfig.tsbuildinfo
*.tsbuildinfo

# Python
__pycache__/
*.py[cod]
*.so
.venv/
venv/

# Docker
*.log

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.idea/
.vscode/

# Generated configs (created from templates by generate-configs.sh)
# Keep the template, ignore the generated file
monitoring/prometheus/prometheus.yml

# Temporary/runtime files
*.tmp

# Personal data - user-specific, not part of project
# RAG source documents
rag_data/
personal_rag/
*_rag/

# ChromaDB vector database
chroma/
*.chroma

# Generated audio files (TTS reminders, etc.)
audio/
*.wav
*.mp3

# Google OAuth2 credentials
credentials/

# TLS certificates
certs/

# Model files (too large for git)
*.gguf
*.safetensors
*.bin
*.pt
*.pth
secrets.yaml

# Claude Code runtime artifacts
.claude/scheduled_tasks.lock

# qwen-code project-scoped runtime (created when running `qwen` in repo dir)
.qwen/
QWEN.md
