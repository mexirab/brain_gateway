# NOTE: This Caddyfile is NOT currently wired into docker-compose.yml.
# It's a reference config. Update hostnames + add a caddy service to activate.

# Main brain interface
http://helios:3000 {
    reverse_proxy open-webui:8080
}

# Or if you want to use port 80 directly
http://:80 {
    reverse_proxy open-webui:8080
}

# Monitoring
http://:3001 {
    reverse_proxy uptime-kuma:3001
}

# Portainer
http://:9000 {
    reverse_proxy portainer:9000
}

# Grafana
http://:3002 {
    reverse_proxy grafana:3000
}
