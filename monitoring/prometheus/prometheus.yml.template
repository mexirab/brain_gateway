# Prometheus Configuration for Brain Gateway Cluster
# ==================================================
# TEMPLATE FILE - Do not edit directly!
#
# This file uses environment variable placeholders that are
# substituted by scripts/generate-configs.sh using envsubst.
#
# After editing this template, run:
#   ./scripts/generate-configs.sh
#
# Network Architecture (v7 unified + split deployment):
#
#   Jupiter: ${NODE_JUPITER_IP} (Always-on hub: orchestrator, frontend, Home Assistant,
#                                 monitoring stack — prometheus/grafana/loki/alertmanager,
#                                 Pi-hole primary, conjure API, netdata)
#   Helios:  ${NODE_HELIOS_IP}  (GPU model layer: primary LLM on RTX 5090, TTS/STT + code
#                                 agent on RTX PRO 5000 — power-tiered, asleep most of the time)
#   Saturn:  ${NODE_SATURN_IP}  (Vision model on RTX 3080, expert model on RTX 3090,
#                                 Pi-hole secondary)
#   Uranus:  ${NODE_URANUS_IP}  (ComfyUI/Conjure on 2x RTX 5080)

global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - /etc/prometheus/alert-rules.yml

# Alertmanager runs in the same compose project / docker network
# (monitoring/docker-compose.yml), so the bare service name resolves.
alerting:
  alertmanagers:
    - static_configs:
        - targets: ["alertmanager:9093"]

scrape_configs:
  # ============================================
  # PROMETHEUS SELF-MONITORING
  # ============================================
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']
        labels:
          node: 'jupiter'

  # ============================================
  # NODE EXPORTERS - System Metrics
  # ============================================
  - job_name: 'node-exporter'
    static_configs:
      # Jupiter (Pi-hole primary + monitoring stack, no GPU)
      - targets: ['${NODE_JUPITER_IP}:9100']
        labels:
          node: 'jupiter'
          role: 'monitoring+pihole'

      # Helios (Gateway + primary LLM + TTS/STT + coder)
      - targets: ['${NODE_HELIOS_IP}:9100']
        labels:
          node: 'helios'
          role: 'gateway'
          gpu: 'rtx5090+rtx-pro-5000'

      # Uranus (ComfyUI / Conjure on 2x RTX 5080)
      - targets: ['${NODE_URANUS_IP}:9100']
        labels:
          node: 'uranus'
          role: 'comfyui'
          gpu: '2x-rtx5080'

      # Saturn (Vision model + Pi-hole secondary)
      - targets: ['${NODE_SATURN_IP}:9100']
        labels:
          node: 'saturn'
          role: 'vision+pihole-secondary'
          gpu: 'rtx3080+rtx3090'

  # ============================================
  # GPU EXPORTERS - NVIDIA Metrics
  # ============================================
  - job_name: 'gpu-exporter'
    static_configs:
      - targets: ['${NODE_HELIOS_IP}:${MONITORING_GPU_EXPORTER_PORT}']
        labels:
          node: 'helios'
          gpu: 'rtx5090+rtx-pro-5000'

      - targets: ['${NODE_URANUS_IP}:${MONITORING_GPU_EXPORTER_PORT}']
        labels:
          node: 'uranus'
          gpu: '2x-rtx5080'

      - targets: ['${NODE_SATURN_IP}:${MONITORING_GPU_EXPORTER_PORT}']
        labels:
          node: 'saturn'
          gpu: 'rtx3080+rtx3090'

  # ============================================
  # CONJURE API METRICS
  # ============================================
  # Conjure runs as a bare PM2 process on Jupiter (port 5050).
  - job_name: 'conjure'
    scrape_interval: 15s
    static_configs:
      - targets: ['${NODE_JUPITER_IP}:5050']
        labels:
          service: 'conjure-api'
          node: 'jupiter'

  # ============================================
  # HTTP HEALTH PROBES (Blackbox Exporter)
  # ============================================
  - job_name: 'blackbox-http'
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:
      # Brain Gateway Orchestrator (Jupiter — moved off Helios with power-tiering)
      - targets: ['http://${NODE_JUPITER_IP}:${SERVICE_ORCHESTRATOR_PORT}/health']
        labels:
          service: 'orchestrator'
          node: 'jupiter'

      # TTS (Qwen3-TTS on Helios GPU1)
      - targets: ['http://${NODE_HELIOS_IP}:${SERVICE_TTS_PORT}/health']
        labels:
          service: 'tts'
          node: 'helios'

      # STT (Whisper on Helios GPU1)
      - targets: ['http://${NODE_HELIOS_IP}:${SERVICE_STT_PORT}/health']
        labels:
          service: 'stt'
          node: 'helios'

      # Primary LLM (llama-server on Helios GPU1)
      - targets: ['http://${NODE_HELIOS_IP}:8080/v1/models']
        labels:
          service: 'llama-primary'
          node: 'helios'

      # Code agent (llama-server on Helios GPU0)
      - targets: ['http://${NODE_HELIOS_IP}:8082/v1/models']
        labels:
          service: 'llama-coder'
          node: 'helios'

      # Vision model (Qwen2.5-VL-7B on Saturn)
      - targets: ['http://${NODE_SATURN_IP}:8010/v1/models']
        labels:
          service: 'vision'
          node: 'saturn'

      # Conjure API (PM2 on Jupiter)
      - targets: ['http://${NODE_JUPITER_IP}:5050/health']
        labels:
          service: 'conjure'
          node: 'jupiter'

      # Actual Budget (docker on Jupiter). tier=app is load-bearing: the
      # AppDown alert keys on probe_success{tier="app"} == 0 (Grafana
      # visibility only — AppDown is not in the Pushover route).
      - targets: ['http://${NODE_JUPITER_IP}:5006']
        labels:
          service: 'actual'
          node: 'jupiter'
          tier: 'app'

    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: blackbox-exporter:9115

  # ============================================
  # BRAIN GATEWAY ORCHESTRATOR METRICS
  # ============================================
  - job_name: 'orchestrator'
    metrics_path: /metrics
    scrape_interval: 15s
    authorization:
      type: Bearer
      credentials_file: /etc/prometheus/api_token
    static_configs:
      - targets: ['${NODE_JUPITER_IP}:${SERVICE_ORCHESTRATOR_PORT}']
        labels:
          service: 'orchestrator'
          node: 'jupiter'

  # ============================================
  # UPS METRICS (NUT exporter on Helios)
  # ============================================
  # Both UPSes are USB-attached to Helios; the NUT systemd service reads them
  # and the nut_exporter Docker container exposes /ups_metrics on port 9199.
  # The exporter requires `?ups=<name>` per scrape, so we use relabeling to
  # turn the static targets into URL params and tag each series with `ups`.
  #
  # CyberPower CP1500PFCLCD (1000W) exposes ups.load + input/output voltage.
  # Goldenmate 2000VA LiFePO4 (iDowell chipset) only exposes status + battery
  # state — no load watts available from firmware. For Goldenmate watts, use
  # a Kasa/Tapo smart plug at the wall (separate ingestion via Home Assistant)
  # or sum nvidia-smi power draw on Helios.
  - job_name: 'nut'
    metrics_path: /ups_metrics
    scrape_interval: 15s
    static_configs:
      - targets: ['cyberpower', 'goldenmate']
        labels:
          node: 'helios'
    relabel_configs:
      - source_labels: [__address__]
        target_label: ups
      - source_labels: [__address__]
        target_label: __param_ups
      - target_label: __address__
        replacement: '${NODE_HELIOS_IP}:9199'

  # ============================================
  # NETDATA - Detailed System Metrics
  # ============================================
  - job_name: 'netdata'
    metrics_path: /api/v1/allmetrics
    params:
      format: [prometheus]
    honor_labels: true
    scrape_interval: 30s
    static_configs:
      - targets: ['${NODE_JUPITER_IP}:19999']
        labels:
          node: 'jupiter'
          source: 'netdata'
      - targets: ['${NODE_SATURN_IP}:19999']
        labels:
          node: 'saturn'
          source: 'netdata'
      - targets: ['${NODE_URANUS_IP}:19999']
        labels:
          node: 'uranus'
          source: 'netdata'
      - targets: ['${NODE_HELIOS_IP}:19999']
        labels:
          node: 'helios'
          source: 'netdata'
