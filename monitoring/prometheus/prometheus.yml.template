# Prometheus Configuration for Brain Gateway Cluster
# ==================================================
# TEMPLATE FILE - Do not edit directly!
#
# This file uses environment variable placeholders that are
# substituted by scripts/generate-configs.sh using envsubst.
#
# After editing this template, run:
#   ./scripts/generate-configs.sh
#
# Network Architecture (v7 unified):
#
#   Helios:  ${NODE_HELIOS_IP}  (Gateway + Docker host + Primary LLM on RTX PRO 5000,
#                                 TTS/STT on PRO 5000, Code agent on RTX 5090)
#   Saturn:  ${NODE_SATURN_IP}  (Vision model Qwen2.5-VL-7B on RTX 3080)
#   Uranus:  ${NODE_URANUS_IP}  (ComfyUI/Conjure on 2x RTX 5080)

global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  # ============================================
  # PROMETHEUS SELF-MONITORING
  # ============================================
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']
        labels:
          node: 'helios'

  # ============================================
  # NODE EXPORTERS - System Metrics
  # ============================================
  - job_name: 'node-exporter'
    static_configs:
      # Helios (Gateway + primary LLM + TTS/STT + coder)
      - targets: ['${NODE_HELIOS_IP}:9100']
        labels:
          node: 'helios'
          role: 'gateway'
          gpu: 'rtx5090+rtx-pro-5000'

      # Saturn (Vision model on RTX 3080)
      - targets: ['${NODE_SATURN_IP}:9100']
        labels:
          node: 'saturn'
          role: 'vision'
          gpu: 'rtx3080+rtx3090'

      # Uranus (ComfyUI / Conjure on 2x RTX 5080)
      - targets: ['${NODE_URANUS_IP}:9100']
        labels:
          node: 'uranus'
          role: 'comfyui'
          gpu: '2x-rtx5080'

  # ============================================
  # GPU EXPORTERS - NVIDIA Metrics
  # ============================================
  - job_name: 'gpu-exporter'
    static_configs:
      - targets: ['${NODE_HELIOS_IP}:${MONITORING_GPU_EXPORTER_PORT}']
        labels:
          node: 'helios'
          gpu: 'rtx5090+rtx-pro-5000'

      - targets: ['${NODE_URANUS_IP}:${MONITORING_GPU_EXPORTER_PORT}']
        labels:
          node: 'uranus'
          gpu: '2x-rtx5080'

      - targets: ['${NODE_SATURN_IP}:${MONITORING_GPU_EXPORTER_PORT}']
        labels:
          node: 'saturn'
          gpu: 'rtx3080+rtx3090'

  # ============================================
  # HTTP HEALTH PROBES (Blackbox Exporter)
  # ============================================
  # Requires blackbox exporter running in monitoring stack
  - job_name: 'blackbox-http'
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:
      # Brain Gateway Orchestrator
      - targets: ['http://${NODE_HELIOS_IP}:${SERVICE_ORCHESTRATOR_PORT}/health']
        labels:
          service: 'orchestrator'
          node: 'helios'

      # TTS (Qwen3-TTS on Helios GPU1)
      - targets: ['http://${NODE_HELIOS_IP}:${SERVICE_TTS_PORT}/health']
        labels:
          service: 'tts'
          node: 'helios'

      # STT (Whisper on Helios GPU1)
      - targets: ['http://${NODE_HELIOS_IP}:${SERVICE_STT_PORT}/health']
        labels:
          service: 'stt'
          node: 'helios'

      # Vision model (Saturn)
      - targets: ['http://${NODE_SATURN_IP}:8010/v1/models']
        labels:
          service: 'vision'
          node: 'saturn'

    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: blackbox-exporter:9115  # Blackbox exporter address

  # NOTE: llama-server instances (primary on 8080, coder on 8082) don't expose
  # Prometheus /metrics by default. Monitor them via logs in Loki instead, or
  # via the orchestrator's own metrics endpoint if enabled.
