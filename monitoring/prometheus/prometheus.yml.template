# Prometheus Configuration for Brain Gateway Cluster
# ==================================================
# TEMPLATE FILE - Do not edit directly!
#
# This file uses environment variable placeholders that are
# substituted by scripts/generate-configs.sh using envsubst.
#
# After editing this template, run:
#   ./scripts/generate-configs.sh
#
# Network Architecture (v7 unified + split deployment):
#
#   Jupiter: ${NODE_JUPITER_IP} (Pi-hole primary, monitoring stack — prometheus/grafana/loki,
#                                 conjure API, netdata)
#   Helios:  ${NODE_HELIOS_IP}  (Brain gateway, primary LLM on RTX PRO 5000, TTS/STT on PRO 5000,
#                                 code agent Qwen2.5-Coder-32B on RTX 5090, always-on)
#   Saturn:  ${NODE_SATURN_IP}  (Vision model Qwen2.5-VL-7B on RTX 3080, Pi-hole secondary)
#   Uranus:  ${NODE_URANUS_IP}  (ComfyUI/Conjure on 2x RTX 5080)

global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - /etc/prometheus/alert-rules.yml

scrape_configs:
  # ============================================
  # PROMETHEUS SELF-MONITORING
  # ============================================
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']
        labels:
          node: 'jupiter'

  # ============================================
  # NODE EXPORTERS - System Metrics
  # ============================================
  - job_name: 'node-exporter'
    static_configs:
      # Jupiter (Pi-hole primary + monitoring stack, no GPU)
      - targets: ['${NODE_JUPITER_IP}:9100']
        labels:
          node: 'jupiter'
          role: 'monitoring+pihole'

      # Helios (Gateway + primary LLM + TTS/STT + coder)
      - targets: ['${NODE_HELIOS_IP}:9100']
        labels:
          node: 'helios'
          role: 'gateway'
          gpu: 'rtx5090+rtx-pro-5000'

      # Uranus (ComfyUI / Conjure on 2x RTX 5080)
      - targets: ['${NODE_URANUS_IP}:9100']
        labels:
          node: 'uranus'
          role: 'comfyui'
          gpu: '2x-rtx5080'

      # Saturn (Vision model + Pi-hole secondary)
      - targets: ['${NODE_SATURN_IP}:9100']
        labels:
          node: 'saturn'
          role: 'vision+pihole-secondary'
          gpu: 'rtx3080+rtx3090'

  # ============================================
  # GPU EXPORTERS - NVIDIA Metrics
  # ============================================
  - job_name: 'gpu-exporter'
    static_configs:
      - targets: ['${NODE_HELIOS_IP}:${MONITORING_GPU_EXPORTER_PORT}']
        labels:
          node: 'helios'
          gpu: 'rtx5090+rtx-pro-5000'

      - targets: ['${NODE_URANUS_IP}:${MONITORING_GPU_EXPORTER_PORT}']
        labels:
          node: 'uranus'
          gpu: '2x-rtx5080'

      - targets: ['${NODE_SATURN_IP}:${MONITORING_GPU_EXPORTER_PORT}']
        labels:
          node: 'saturn'
          gpu: 'rtx3080+rtx3090'

  # ============================================
  # CONJURE API METRICS
  # ============================================
  # Conjure runs as a bare PM2 process on Jupiter (port 5050).
  - job_name: 'conjure'
    scrape_interval: 15s
    static_configs:
      - targets: ['${NODE_JUPITER_IP}:5050']
        labels:
          service: 'conjure-api'
          node: 'jupiter'

  # ============================================
  # HTTP HEALTH PROBES (Blackbox Exporter)
  # ============================================
  - job_name: 'blackbox-http'
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:
      # Brain Gateway Orchestrator (Helios)
      - targets: ['http://${NODE_HELIOS_IP}:${SERVICE_ORCHESTRATOR_PORT}/health']
        labels:
          service: 'orchestrator'
          node: 'helios'

      # TTS (Qwen3-TTS on Helios GPU1)
      - targets: ['http://${NODE_HELIOS_IP}:${SERVICE_TTS_PORT}/health']
        labels:
          service: 'tts'
          node: 'helios'

      # STT (Parakeet TDT v3 on Helios GPU1)
      - targets: ['http://${NODE_HELIOS_IP}:${SERVICE_STT_PORT}/health']
        labels:
          service: 'stt'
          node: 'helios'

      # Primary LLM (vllm-primary on Helios GPU0 — Lorbus/Qwen3.6-27B-int4-AutoRound, since 2026-04-26 Phase 3 cutover)
      - targets: ['http://${NODE_HELIOS_IP}:8080/v1/models']
        labels:
          service: 'llama-primary'
          node: 'helios'

      # Code agent (llama-server-coder on Helios GPU1 — repinned GPU0→GPU1 at Phase 3 cutover)
      - targets: ['http://${NODE_HELIOS_IP}:8082/v1/models']
        labels:
          service: 'llama-coder'
          node: 'helios'

      # Vision model (Qwen2.5-VL-7B on Saturn)
      - targets: ['http://${NODE_SATURN_IP}:8010/v1/models']
        labels:
          service: 'vision'
          node: 'saturn'

      # Conjure API (PM2 on Jupiter)
      - targets: ['http://${NODE_JUPITER_IP}:5050/health']
        labels:
          service: 'conjure'
          node: 'jupiter'

    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: blackbox-exporter:9115

  # ============================================
  # BRAIN GATEWAY ORCHESTRATOR METRICS
  # ============================================
  - job_name: 'orchestrator'
    metrics_path: /metrics
    scrape_interval: 15s
    authorization:
      type: Bearer
      credentials_file: /etc/prometheus/api_token
    static_configs:
      - targets: ['${NODE_HELIOS_IP}:${SERVICE_ORCHESTRATOR_PORT}']
        labels:
          service: 'orchestrator'
          node: 'helios'

  # ============================================
  # NETDATA - Detailed System Metrics
  # ============================================
  - job_name: 'netdata'
    metrics_path: /api/v1/allmetrics
    params:
      format: [prometheus]
    honor_labels: true
    scrape_interval: 30s
    static_configs:
      - targets: ['${NODE_JUPITER_IP}:19999']
        labels:
          node: 'jupiter'
          source: 'netdata'
      - targets: ['${NODE_SATURN_IP}:19999']
        labels:
          node: 'saturn'
          source: 'netdata'
      - targets: ['${NODE_URANUS_IP}:19999']
        labels:
          node: 'uranus'
          source: 'netdata'
      - targets: ['${NODE_HELIOS_IP}:19999']
        labels:
          node: 'helios'
          source: 'netdata'
