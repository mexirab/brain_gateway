# Prometheus Configuration for Brain Gateway Cluster
# ==================================================
# TEMPLATE FILE - Do not edit directly!
#
# This file uses environment variable placeholders that are
# substituted by scripts/generate-configs.sh using envsubst.
#
# After editing this template, run:
#   ./scripts/generate-configs.sh
#
# Network Architecture (Voice-First ADHD Support):
#
# ALWAYS-ON:
#   Jupiter:  ${NODE_JUPITER_IP} (Orchestrator, no GPU)
#   Saturn:   ${NODE_SATURN_IP}  (Nemotron-8B brain on RTX 3090)
#   Uranus:   ${NODE_URANUS_IP}  (TTS on GPU 0, STT on GPU 1 - 2x RTX 5080)
#
# OFF BY DEFAULT (saves ~150W):
#   Helios:   ${NODE_HELIOS_IP}  (Expert 120B on RTX 5090 + RAM)

global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  # ============================================
  # PROMETHEUS SELF-MONITORING
  # ============================================
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']
        labels:
          node: 'jupiter'

  # ============================================
  # NODE EXPORTERS - System Metrics
  # ============================================
  - job_name: 'node-exporter'
    static_configs:
      # Jupiter (Docker host, no GPU)
      - targets: ['node-exporter:9100']
        labels:
          node: 'jupiter'
          role: 'gateway'

      # Helios (Large models, RTX 5090 32GB)
      - targets: ['${NODE_HELIOS_IP}:9100']
        labels:
          node: 'helios'
          role: 'expert'
          gpu: 'rtx5090'

      # Uranus (2x RTX 5080 16GB each - available)
      - targets: ['${NODE_URANUS_IP}:9100']
        labels:
          node: 'uranus'
          role: 'available'
          gpu: '2x-rtx5080'

      # Saturn (Nemotron brain on RTX 3090, RTX 3080 available)
      - targets: ['${NODE_SATURN_IP}:9100']
        labels:
          node: 'saturn'
          role: 'brain'
          gpu: 'rtx3080+rtx3090'

      # Jupiter (No GPU currently)
      - targets: ['${NODE_JUPITER_IP}:9100']
        labels:
          node: 'jupiter'
          role: 'compute'

  # ============================================
  # GPU EXPORTERS - NVIDIA Metrics
  # ============================================
  - job_name: 'gpu-exporter'
    static_configs:
      # Helios GPU (Expert model - RTX 5090)
      - targets: ['${NODE_HELIOS_IP}:${MONITORING_GPU_EXPORTER_PORT}']
        labels:
          node: 'helios'
          gpu: 'rtx5090'

      # Uranus GPUs (Nemotron - 2x RTX 5080)
      - targets: ['${NODE_URANUS_IP}:${MONITORING_GPU_EXPORTER_PORT}']
        labels:
          node: 'uranus'
          gpu: '2x-rtx5080'

      # Saturn GPUs (RTX 3080 + RTX 3090)
      - targets: ['${NODE_SATURN_IP}:${MONITORING_GPU_EXPORTER_PORT}']
        labels:
          node: 'saturn'
          gpu: 'rtx3080+rtx3090'

  # ============================================
  # LLM SERVICE METRICS (vLLM exposes /metrics)
  # ============================================
  - job_name: 'llm-services'
    metrics_path: /metrics
    static_configs:
      # Nemotron on Saturn (vLLM exposes metrics)
      - targets: ['${NODE_SATURN_IP}:${SERVICE_NEMOTRON_PORT}']
        labels:
          service: 'nemotron'
          node: 'saturn'

  # ============================================
  # HTTP HEALTH PROBES (Blackbox Exporter)
  # ============================================
  # Requires blackbox exporter running in monitoring stack
  - job_name: 'blackbox-http'
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:
      # Brain Gateway Orchestrator
      - targets: ['http://${NODE_JUPITER_IP}:${SERVICE_ORCHESTRATOR_PORT}/health']
        labels:
          service: 'orchestrator'
          node: 'jupiter'

      # TTS (Qwen3-TTS on Uranus GPU 0)
      - targets: ['http://${NODE_URANUS_IP}:${SERVICE_TTS_PORT}/health']
        labels:
          service: 'tts'
          node: 'uranus'

      # STT (Whisper on Uranus GPU 1)
      - targets: ['http://${NODE_URANUS_IP}:${SERVICE_STT_PORT}/health']
        labels:
          service: 'stt'
          node: 'uranus'

      # Helios Expert Model (OFF by default)
      - targets: ['http://${NODE_HELIOS_IP}:${SERVICE_HELIOS_PORT}/health']
        labels:
          service: 'helios'
          node: 'helios'

    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: blackbox-exporter:9115  # Blackbox exporter address

  # NOTE: Orchestrator, LiteLLM, and Helios LLM don't expose /metrics
  # Monitor them via logs in Loki instead
