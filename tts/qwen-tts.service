[Unit]
Description=Qwen3-TTS Server for Brain Gateway
After=network.target

[Service]
Type=simple
User=labadmin
Group=labadmin
WorkingDirectory=/home/labadmin

# Virtual environment
Environment="PATH=/home/labadmin/qwen-tts-env/bin:/usr/local/bin:/usr/bin:/bin"
Environment="QWEN_TTS_MODEL=/home/labadmin/models/Qwen3-TTS-1.7B-Base"
Environment="QWEN_TTS_DEVICE=cuda:0"
Environment="QWEN_TTS_PORT=8002"
Environment="QWEN_TTS_DTYPE=bfloat16"
Environment="QWEN_TTS_FLASH_ATTN=false"

ExecStart=/home/labadmin/qwen-tts-env/bin/python /home/labadmin/server.py

Restart=on-failure
RestartSec=10

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=qwen-tts

[Install]
WantedBy=multi-user.target
