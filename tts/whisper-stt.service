[Unit]
Description=Whisper STT Server for Brain Gateway
After=network.target

[Service]
Type=simple
User=nadim
Group=nadim
WorkingDirectory=/home/nadim

# Use same environment as TTS server
Environment="PATH=/home/nadim/qwen-tts-env/bin:/usr/local/bin:/usr/bin:/bin"
Environment="WHISPER_MODEL=base"
Environment="WHISPER_DEVICE=cuda:1"
Environment="WHISPER_PORT=8003"

ExecStart=/home/nadim/qwen-tts-env/bin/python /home/nadim/stt_server.py

Restart=on-failure
RestartSec=10

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=whisper-stt

[Install]
WantedBy=multi-user.target
